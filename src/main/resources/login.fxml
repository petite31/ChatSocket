<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<VBox alignment="CENTER" spacing="20" stylesheets="style.css"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controller.LoginController"
      prefWidth="400" prefHeight="500">

    <Label text="P2P Chat Login" styleClass="title-label"/>

    <VBox spacing="10" maxWidth="250">
        <Label text="Tên hiển thị:" />
        <TextField fx:id="txtUsername" promptText="Nhập tên của bạn..." />

        <Label text="Mật khẩu:" />
        <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu..." />

        <Label text="Port lắng nghe (VD: 5000):" />
        <TextField fx:id="txtPort" text="5000" promptText="Port của bạn" />
    </VBox>

    <Button text="Đăng Nhập" onAction="#handleLogin" prefWidth="250"/>

    <HBox alignment="CENTER" spacing="5">
        <Label text="Chưa có tài khoản?" />
        <Button text="Đăng ký" styleClass="button-secondary" onAction="#goToRegister"/>
    </HBox>
</VBox>